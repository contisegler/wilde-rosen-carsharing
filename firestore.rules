rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow everyone to read everything in cars
    match /cars/{carId}/{document=**} {
      allow read: if true;
    }

    // Allow write to damages only for specific user and specific cars
    match /cars/{carId}/damages/{damageId} {
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.damage_reporter == true;
    }
    
    match /users/{userId} {
      allow read: if request.auth != null
        && request.auth.uid == userId;
    }

    // Deny write for all other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}